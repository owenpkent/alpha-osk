{
  "name": "alpha-osk-telemetry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local",
    "predeploy": "npm run sbom",
    "deploy": "wrangler deploy",
    "schema:local": "wrangler d1 execute alpha-osk-telemetry --local --file schema.sql",
    "schema:remote": "wrangler d1 execute alpha-osk-telemetry --remote --file schema.sql",
    "sbom": "cyclonedx-npm --spec-version 1.6 --output-reproducible --output-format JSON --output-file cf-worker-sbom.cyclonedx.json"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "@cyclonedx/cyclonedx-npm": "^5.0.0",
    "typescript": "^5.4.0",
    "wrangler": "^4.104.0"
  },
  "overrides": {
    "ws": "^8.20.1",
    "undici": "^7.28.0",
    "tar": "^7.5.16",
    "js-yaml": "^4.2.0"
  }
}
